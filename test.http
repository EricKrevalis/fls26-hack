@cloudUrl = https://fls26-mcp-106946411952.europe-west3.run.app

@baseUrl = http://localhost:8000

@mcpPath = /mcp
@sessionId =ce1b105f675f45659b950f2c8388deec

### Step 1: Initialize MCP session
### Run this first.
### Then copy the `mcp-session-id` response header into @sessionId above.
POST {{baseUrl}}{{mcpPath}}
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-06-18",
    "capabilities": {},
    "clientInfo": {
      "name": "rest-client",
      "version": "1.0.0"
    }
  }
}

### Step 2: Notify server that client is initialized
### Run this only after @sessionId has been filled with the header from Step 1.
POST {{baseUrl}}{{mcpPath}}
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "method": "notifications/initialized"
}

### Step 3: List available tools
### This should return both registered tools.
POST {{baseUrl}}{{mcpPath}}
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/list",
  "params": {}
}

### Step 4: Call find_competitor_trials
POST {{baseUrl}}{{mcpPath}}
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "tools/call",
  "params": {
    "name": "find_competitor_trials",
    "arguments": {
      "indication": "NSCLC",
      "phase": "Phase 2",
      "geography": "Europe",
      "include_upcoming": true
    }
  }
}

### Step 5: Call benchmark_trial_design
POST {{baseUrl}}{{mcpPath}}
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "tools/call",
  "params": {
    "name": "benchmark_trial_design",
    "arguments": {
      "sample_size": 180,
      "comparator_type": "standard_of_care",
      "age_min": 18,
      "age_max": 75
    }
  }
}
